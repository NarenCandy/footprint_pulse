# Flask Environment Settings
FLASK_ENV=development
FLASK_APP=wsgi.py

# Security Setting: Secret key for Flask session signing (choose a long random string)
SECRET_KEY=dev_secret_key_change_me_in_production

# AI Setting: Google Gemini API Key for weekly personalized insights
# If left blank or absent, the app will degrade gracefully to rule-based insights
GEMINI_API_KEY=your_gemini_api_key_here
